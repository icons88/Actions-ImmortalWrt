CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
# CR6606
# CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-cr6606=y
# CR6609
# CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-cr6609=y
# CR6608
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-cr6608=y

# 基础核心程序及依赖
CONFIG_PACKAGE_samba4=y
CONFIG_PACKAGE_hd-idle=y
CONFIG_PACKAGE_ddnsto=y
CONFIG_PACKAGE_uugamebooster=y
CONFIG_PACKAGE_luci-app-passwall=y

# 添加的插件
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria is not set
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria2=y
CONFIG_PACKAGE_luci-app-uugamebooster=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-ddnsto=y

# 语言包
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-uugamebooster-zh-cn=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ddnsto-zh-cn=y

# 移除的无用插件
# CONFIG_PACKAGE_autosamba is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-autoreboot is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_luci-app-nlbwmon is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-wol is not set
# CONFIG_PACKAGE_luci-theme-argon is not set

# 构建输出设置
CONFIG_TARGET_IMAGES_GZIP=y
